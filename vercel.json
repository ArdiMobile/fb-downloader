{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/info", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}